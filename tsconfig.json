{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "paths": {
      "@index": ["./src/index"],
      "@type": ["./src/type/index"]
    }
  },
  "include": ["src/**/*.ts"]
}
